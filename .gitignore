# # 默认忽略的文件
# /shelf/
# /workspace.xml
# # 已忽略包含查询文件的默认文件夹
# /queries/
# # Datasource local storage ignored files
# /dataSources/
# /dataSources.local.xml
# # 基于编辑器的 HTTP 客户端请求
# /httpRequests/
# Python 编译缓存 (最重要的)
**/__pycache__/
*.py[cod]
*$py.class

# Django 数据库 (除非组长要求，否则本地数据库不上传)
db.sqlite3

# 虚拟环境
venv/
env/
ENV/

# 编辑器相关 (保留你原来的 IDE 忽略项)
.idea/
.vscode/
/shelf/
/workspace.xml
/queries/
/dataSources/
/dataSources.local.xml
/httpRequests/

# 操作系统临时文件
.DS_Store
Thumbs.db